# ── Silver Tier Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Vault root path (absolute)
VAULT_PATH=C:/D/github/Hackthon-Zero-Silver-Tier-samad-developer-

# Gmail OAuth credentials (generated during Bronze setup)
GMAIL_CREDENTIALS_PATH=./gmail_credentials.json
GMAIL_TOKEN_PATH=./gmail_token.json

# WhatsApp session directory (created by QR setup script)
WHATSAPP_SESSION_PATH=./whatsapp_session

# Safety — keep true until full dry-run passes
DRY_RUN=true

# Rate limiting
MAX_EMAILS_PER_HOUR=10

# Scheduler times (24h format)
DAILY_BRIEFING_TIME=08:00
WEEKLY_BRIEFING_DAY=monday
WEEKLY_BRIEFING_TIME=07:00

# Stale approval threshold (hours)
STALE_APPROVAL_HOURS=4
